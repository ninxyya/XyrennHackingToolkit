<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xyrenn_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_xyrenn_logo"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/xyrenn_secondary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/xyrenn_accent"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/xyrenn_text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="32dp">

            <Button
                android:id="@+id/btnGithub"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="GitHub"
                android:textAllCaps="false"
                android:layout_marginEnd="4dp"
                style="@style/Widget.Xyrenn.Button.Secondary" />

            <Button
                android:id="@+id/btnTelegram"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Telegram"
                android:textAllCaps="false"
                android:layout_marginHorizontal="4dp"
                style="@style/Widget.Xyrenn.Button.Secondary" />

            <Button
                android:id="@+id/btnWebsite"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Website"
                android:textAllCaps="false"
                android:layout_marginStart="4dp"
                style="@style/Widget.Xyrenn.Button.Secondary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnLicense"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="LICENSE"
                android:textAllCaps="false"
                android:layout_marginEnd="4dp"
                style="@style/Widget.Xyrenn.Button.Primary" />

            <Button
                android:id="@+id/btnDisclaimer"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="DISCLAIMER"
                android:textAllCaps="false"
                android:layout_marginStart="4dp"
                style="@style/Widget.Xyrenn.Button.Danger" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>