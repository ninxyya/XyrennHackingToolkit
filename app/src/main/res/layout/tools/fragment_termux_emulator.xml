<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/xyrenn_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/xyrenn_surface_light">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Install:"
            android:textColor="@color/xyrenn_text_primary"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnInstallNmap"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="nmap"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:layout_marginEnd="4dp"
            style="@style/Widget.Xyrenn.Button.Primary" />

        <Button
            android:id="@+id/btnInstallHydra"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="hydra"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:layout_marginEnd="4dp"
            style="@style/Widget.Xyrenn.Button.Primary" />

        <Button
            android:id="@+id/btnInstallSqlmap"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="sqlmap"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:layout_marginEnd="4dp"
            style="@style/Widget.Xyrenn.Button.Primary" />

        <Button
            android:id="@+id/btnInstallMetasploit"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="msf"
            android:textAllCaps="false"
            android:textSize="12sp"
            style="@style/Widget.Xyrenn.Button.Primary" />

    </LinearLayout>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1E1E1E"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00FF00"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp" />

    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/xyrenn_surface_light">

        <EditText
            android:id="@+id/etCommand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Enter command..."
            android:textColor="@color/xyrenn_text_primary"
            android:textColorHint="@color/xyrenn_text_hint"
            android:background="@drawable/bg_input"
            android:padding="8dp"
            android:textSize="14sp"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/btnExecute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EXEC"
            android:textAllCaps="false"
            android:layout_marginStart="8dp"
            android:paddingHorizontal="16dp"
            style="@style/Widget.Xyrenn.Button.Primary" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CLEAR"
            android:textAllCaps="false"
            android:layout_marginStart="4dp"
            android:paddingHorizontal="16dp"
            style="@style/Widget.Xyrenn.Button.Secondary" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:layout_margin="4dp" />

</LinearLayout>