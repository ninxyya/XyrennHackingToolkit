<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/xyrenn_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <EditText
            android:id="@+id/etScriptName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Script name"
            android:textColor="@color/xyrenn_text_primary"
            android:textColorHint="@color/xyrenn_text_hint"
            android:background="@drawable/bg_input"
            android:padding="8dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnSaveScript"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAVE"
            android:textAllCaps="false"
            android:paddingHorizontal="12dp"
            style="@style/Widget.Xyrenn.Button.Primary" />

    </LinearLayout>

    <EditText
        android:id="@+id/etScriptContent"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:hint="Script content"
        android:textColor="@color/xyrenn_text_primary"
        android:textColorHint="@color/xyrenn_text_hint"
        android:background="@drawable/bg_input"
        android:padding="8dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="8dp"
        android:gravity="top"
        android:fontFamily="monospace"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnLoadScripts"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="LOAD SCRIPTS"
            android:textAllCaps="false"
            android:layout_marginEnd="4dp"
            style="@style/Widget.Xyrenn.Button.Secondary" />

        <TextView
            android:id="@+id/tvSelectedScript"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="No script selected"
            android:textColor="@color/xyrenn_text_secondary"
            android:textSize="12sp"
            android:layout_marginHorizontal="4dp" />

        <Button
            android:id="@+id/btnDeleteScript"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="DELETE"
            android:textAllCaps="false"
            android:layout_marginStart="4dp"
            android:enabled="false"
            style="@style/Widget.Xyrenn.Button.Danger" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvScripts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etParams"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Parameters (optional)"
            android:textColor="@color/xyrenn_text_primary"
            android:textColorHint="@color/xyrenn_text_hint"
            android:background="@drawable/bg_input"
            android:padding="8dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnRunScript"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RUN"
            android:textAllCaps="false"
            android:enabled="false"
            android:paddingHorizontal="16dp"
            android:layout_marginEnd="4dp"
            style="@style/Widget.Xyrenn.Button.Primary" />

        <Button
            android:id="@+id/btnStopScript"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STOP"
            android:textAllCaps="false"
            android:enabled="false"
            android:paddingHorizontal="16dp"
            style="@style/Widget.Xyrenn.Button.Danger" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:layout_margin="4dp" />

    <TextView
        android:id="@+id/tvOutput"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@color/xyrenn_surface_light"
        android:textColor="@color/xyrenn_accent"
        android:padding="8dp"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_margin="8dp" />

</LinearLayout>