<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/xyrenn_surface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bluetooth Spoofer"
        android:textColor="@color/xyrenn_secondary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etDeviceName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Spoofed device name"
        android:textColor="@color/xyrenn_text_primary"
        android:textColorHint="@color/xyrenn_text_hint"
        android:background="@drawable/bg_input"
        android:padding="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Device Type:"
        android:textColor="@color/xyrenn_text_primary"
        android:layout_marginTop="8dp" />

    <Spinner
        android:id="@+id/spinnerDeviceType"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_input"
        android:layout_marginTop="4dp" />

    <Button
        android:id="@+id/btnGenerateSpoof"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="GENERATE SPOOFED DEVICE"
        android:textAllCaps="false"
        android:layout_marginTop="16dp"
        style="@style/Widget.Xyrenn.Button.Primary" />

    <TextView
        android:id="@+id/tvSpoofedDevice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No device generated"
        android:textColor="@color/xyrenn_accent"
        android:padding="12dp"
        android:background="@color/xyrenn_surface_light"
        android:layout_marginVertical="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnStartAdvertising"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="START ADVERTISING"
            android:textAllCaps="false"
            android:layout_marginEnd="4dp"
            android:enabled="false"
            style="@style/Widget.Xyrenn.Button.Primary" />

        <Button
            android:id="@+id/btnStopAdvertising"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="STOP"
            android:textAllCaps="false"
            android:layout_marginStart="4dp"
            android:enabled="false"
            style="@style/Widget.Xyrenn.Button.Secondary" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:layout_margin="8dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textColor="@color/xyrenn_text_secondary"
        android:layout_marginTop="8dp" />

</LinearLayout>