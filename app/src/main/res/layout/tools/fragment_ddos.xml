<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/xyrenn_surface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DDoS Attack"
        android:textColor="@color/xyrenn_secondary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etTargetIp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Target IP"
        android:textColor="@color/xyrenn_text_primary"
        android:textColorHint="@color/xyrenn_text_hint"
        android:background="@drawable/bg_input"
        android:padding="12dp" />

    <EditText
        android:id="@+id/etPort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Port (default: 80)"
        android:textColor="@color/xyrenn_text_primary"
        android:textColorHint="@color/xyrenn_text_hint"
        android:background="@drawable/bg_input"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:inputType="number"
        android:text="80" />

    <EditText
        android:id="@+id/etDuration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Duration (seconds)"
        android:textColor="@color/xyrenn_text_primary"
        android:textColorHint="@color/xyrenn_text_hint"
        android:background="@drawable/bg_input"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:inputType="number"
        android:text="10" />

    <EditText
        android:id="@+id/etThreads"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Threads"
        android:textColor="@color/xyrenn_text_primary"
        android:textColorHint="@color/xyrenn_text_hint"
        android:background="@drawable/bg_input"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:inputType="number"
        android:text="5" />

    <Button
        android:id="@+id/btnStartAttack"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="START ATTACK"
        android:textAllCaps="false"
        android:layout_marginTop="16dp"
        style="@style/Widget.Xyrenn.Button.Danger" />

    <Button
        android:id="@+id/btnStopAttack"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="STOP"
        android:textAllCaps="false"
        android:layout_marginTop="8dp"
        android:enabled="false"
        style="@style/Widget.Xyrenn.Button.Secondary" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:layout_margin="8dp" />

    <TextView
        android:id="@+id/tvPacketsSent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Packets: 0"
        android:textColor="@color/xyrenn_text_secondary"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textColor="@color/xyrenn_text_secondary"
        android:layout_marginTop="4dp" />

</LinearLayout>