<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/xyrenn_surface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WiFi Killer"
        android:textColor="@color/xyrenn_secondary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etTargetSsid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Target SSID"
        android:textColor="@color/xyrenn_text_primary"
        android:textColorHint="@color/xyrenn_text_hint"
        android:background="@drawable/bg_input"
        android:padding="12dp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnScan"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="SCAN NETWORKS"
        android:textAllCaps="false"
        style="@style/Widget.Xyrenn.Button.Secondary" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:layout_margin="16dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textColor="@color/xyrenn_text_secondary"
        android:layout_marginVertical="8dp" />

    <Button
        android:id="@+id/btnAttack"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="START ATTACK"
        android:textAllCaps="false"
        style="@style/Widget.Xyrenn.Button.Danger" />

    <TextView
        android:id="@+id/tvAttackStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Idle"
        android:textColor="@color/xyrenn_text_secondary"
        android:layout_marginTop="8dp" />

</LinearLayout>