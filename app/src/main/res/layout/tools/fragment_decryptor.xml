<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/xyrenn_surface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Text Decryptor"
        android:textColor="@color/xyrenn_secondary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etInput"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:hint="Encrypted text"
        android:textColor="@color/xyrenn_text_primary"
        android:textColorHint="@color/xyrenn_text_hint"
        android:background="@drawable/bg_input"
        android:padding="12dp"
        android:gravity="top"
        android:minLines="3" />

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Password"
        android:textColor="@color/xyrenn_text_primary"
        android:textColorHint="@color/xyrenn_text_hint"
        android:background="@drawable/bg_input"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:inputType="textPassword" />

    <Button
        android:id="@+id/btnDecrypt"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="DECRYPT"
        android:textAllCaps="false"
        android:layout_marginTop="16dp"
        style="@style/Widget.Xyrenn.Button.Primary" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:layout_margin="8dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textColor="@color/xyrenn_text_secondary"
        android:layout_marginVertical="8dp" />

    <TextView
        android:id="@+id/tvOutput"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@color/xyrenn_surface_light"
        android:textColor="@color/xyrenn_accent"
        android:padding="8dp"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:text="Decrypted text will appear here" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btnPaste"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="PASTE"
            android:textAllCaps="false"
            android:layout_marginEnd="4dp"
            style="@style/Widget.Xyrenn.Button.Secondary" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="CLEAR"
            android:textAllCaps="false"
            android:layout_marginStart="4dp"
            style="@style/Widget.Xyrenn.Button.Secondary" />

    </LinearLayout>

</LinearLayout>